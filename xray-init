#!/bin/sh /etc/rc.common
START=99
STOP=10
USE_PROCD=1
PROG=/usr/local/bin/xray
CONFIG=/usr/local/etc/xray/config.json

start_service() {
    mkdir -p /var/log/xray
    /usr/local/bin/xray-tproxy-setup.sh
    procd_open_instance
    procd_set_param command $PROG run -c $CONFIG
    procd_set_param env XRAY_LOCATION_ASSET=/usr/local/etc/xray
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/xray.pid
    procd_close_instance
}

stop_service() {
    nft delete table inet xray_tproxy 2>/dev/null
    ip rule del fwmark 1 lookup 100 2>/dev/null
}

reload_service() {
    stop_service
    sleep 1
    start_service
}
